POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=construction_dw
POSTGRES_USER=construction
POSTGRES_PASSWORD=construction_dev_password
LOG_LEVEL=INFO
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=3
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
QUALITY_METRICS_FILE=quality_metrics.json
REJECT_THRESHOLD=0.05
WAREHOUSE_SCHEMA=construction_dw
WAREHOUSE_TARGET=postgresql
# DATABASE_URL can override all individual PostgreSQL variables.
# CONFIG_FILE=config/settings.yaml

# Optional Snowflake cloud mode. Leave blank for local PostgreSQL mode.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=CONSTRUCTION_DW
SNOWFLAKE_SCHEMA=CONSTRUCTION_DW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=
